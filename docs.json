{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Irora Developer Hub",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#1e3a5f"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Irora-dev"
      },
      {
        "label": "Support",
        "href": "mailto:support@irora.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Keys",
      "href": "https://irora.ai/keys"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "platform/authentication",
              "platform/errors",
              "platform/rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "VerifAI SEC",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "verifai-sec/index",
              "verifai-sec/quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "verifai-sec/guides/form-types",
              "verifai-sec/guides/risk-scoring",
              "verifai-sec/guides/search",
              "verifai-sec/guides/api-suite"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "VerifAI SEC API",
            "pages": [
              "verifai-sec/api-reference/introduction"
            ]
          }
        ],
        "openapi": "verifai-sec/openapi.yaml"
      }
    ]
  },
  "variables": {
    "companyName": "Irora",
    "supportEmail": "support@irora.ai",
    "githubOrg": "Irora-dev",
    "docsUrl": "https://docs.irora.ai"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Irora-dev",
      "linkedin": "https://linkedin.com/company/irora",
      "x": "https://x.com/irora_ai"
    },
    "links": [
      {
        "header": "Products",
        "items": [
          {
            "label": "VerifAI SEC",
            "href": "/verifai-sec"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "API Reference",
            "href": "/verifai-sec/api-reference/introduction"
          },
          {
            "label": "Status",
            "href": "https://status.irora.ai"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/Irora-dev"
          },
          {
            "label": "Contact",
            "href": "mailto:support@irora.ai"
          }
        ]
      }
    ]
  }
}
