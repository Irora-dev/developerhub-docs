{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Suite by Irora",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#1e3a5f"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "background": {
    "decoration": "gradient"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Irora-dev"
      },
      {
        "label": "Support",
        "href": "mailto:support@irora.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Keys",
      "href": "https://irora.ai/keys"
    }
  },
  "rounded": "default",
  "font": {
    "headings": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "icon": "layer-group",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "platform/authentication",
              "platform/errors",
              "platform/rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "Irora SEC",
        "icon": "file-contract",
        "groups": [
          {
            "group": "Overview",
            "icon": "compass",
            "pages": [
              "irora-sec/index",
              "irora-sec/quickstart"
            ]
          },
          {
            "group": "Core Guides",
            "icon": "book",
            "pages": [
              "irora-sec/guides/form-types",
              "irora-sec/guides/search",
              "irora-sec/guides/natural-language-search",
              "irora-sec/guides/risk-scoring",
              "irora-sec/guides/change-detection"
            ]
          },
          {
            "group": "Data Sources",
            "icon": "database",
            "pages": [
              "irora-sec/guides/insider-trading",
              "irora-sec/guides/politician-trades"
            ]
          },
          {
            "group": "Features",
            "icon": "wand-magic-sparkles",
            "pages": [
              "irora-sec/guides/watchlists",
              "irora-sec/guides/alerts",
              "irora-sec/guides/webhooks"
            ]
          },
          {
            "group": "Platform",
            "icon": "gear",
            "pages": [
              "irora-sec/guides/pricing",
              "irora-sec/guides/api-suite"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "terminal",
        "groups": [
          {
            "group": "Irora SEC API",
            "icon": "code",
            "pages": [
              "irora-sec/api-reference/introduction"
            ]
          }
        ],
        "openapi": "irora-sec/openapi.yaml"
      }
    ]
  },
  "variables": {
    "companyName": "Irora",
    "supportEmail": "support@irora.ai",
    "githubOrg": "Irora-dev",
    "docsUrl": "https://docs.irora.ai"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Irora-dev",
      "linkedin": "https://linkedin.com/company/irora",
      "x": "https://x.com/irora_ai"
    },
    "links": [
      {
        "header": "Products",
        "items": [
          {
            "label": "Irora SEC",
            "href": "/irora-sec"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "API Reference",
            "href": "/irora-sec/api-reference/introduction"
          },
          {
            "label": "Quickstart",
            "href": "/irora-sec/quickstart"
          },
          {
            "label": "Status",
            "href": "https://status.irora.ai"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/Irora-dev"
          },
          {
            "label": "Contact",
            "href": "mailto:support@irora.ai"
          }
        ]
      }
    ]
  }
}
